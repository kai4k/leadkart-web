# Public env vars (visible to the SPA bundle). Production values
# injected at build/deploy time; defaults below match local dev.

# Base URL for leadkart-go API. In dev, leave unset — vite proxies
# /api/* to localhost:8080. In production, set to the deployed
# leadkart-go URL (e.g. https://api.leadkart.in).
PUBLIC_API_BASE_URL=
